# 必填：高德 Web 服务 Key（https://console.amap.com/dev/key/app）
# 部署到 Vercel 等云平台时，IP 白名单请选「不限制」
AMAP_KEY=你的高德Web服务Key

# 可选：聚合数据 12306 火车票查询（有则显示真实车次与二等/一等票价）
# https://www.juhe.cn/docs/api/id/63
JUHE_TRAIN_KEY=

# 可选：Upstash Redis 跨实例缓存（Serverless 多节点部署时推荐）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== 个人自用 OTA 真爬（勿商用，全国任意城市） =====
# 开启后酒店/门票会尝试爬携程/美团等实价（未登录携程通常无房价）
ENABLE_OTA_SCRAPE=false
# fetch（默认）| playwright（本地安装 playwright 后更稳）
OTA_SCRAPE_MODE=fetch
# 单次爬取超时毫秒
OTA_SCRAPE_TIMEOUT_MS=12000
# 首次请运行 npm run scrape:login，在弹出浏览器中过验证码并登录携程账号
# OTA_HEADFUL=1
